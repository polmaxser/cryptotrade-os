# ─── Application ───────────────────────────────────────────────
NODE_ENV=development

# ─── Web (Next.js) ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# ─── API (NestJS) ──────────────────────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000

# ─── Auth ───────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-to-a-long-random-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30
AUTH_COOKIE_DOMAIN=localhost

# ─── Billing (Stripe) ──────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STANDARD=
STRIPE_PRICE_ID_PREMIUM=
BILLING_CHECKOUT_SUCCESS_URL=http://localhost:3000/settings?checkout=success
BILLING_CHECKOUT_CANCEL_URL=http://localhost:3000/pricing?checkout=cancelled
BILLING_PORTAL_RETURN_URL=http://localhost:3000/settings

# ─── Storage (S3-compatible — journal screenshots) ─────────────
# Defaults below point at the bundled MinIO container, so uploads
# work out of the box in local dev. In production, point these at
# a real S3 / Cloudflare R2 / DigitalOcean Spaces bucket instead.
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=cryptotrade-journal
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin
STORAGE_FORCE_PATH_STYLE=true
STORAGE_PUBLIC_URL_BASE=http://localhost:9000/cryptotrade-journal

# ─── Database (PostgreSQL) ─────────────────────────────────────
DATABASE_URL=postgresql://cryptotrade:cryptotrade@localhost:5432/cryptotrade?schema=public

# ─── Docker PostgreSQL ─────────────────────────────────────────
POSTGRES_USER=cryptotrade
POSTGRES_PASSWORD=cryptotrade
POSTGRES_DB=cryptotrade
POSTGRES_PORT=5432

# ─── Docker MinIO ───────────────────────────────────────────────
STORAGE_PORT=9000
STORAGE_CONSOLE_PORT=9001
