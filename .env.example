# ─── Application ───────────────────────────────────────────────
NODE_ENV=development

# ─── Web (Next.js) ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# ─── API (NestJS) ──────────────────────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000

# ─── Database (PostgreSQL) ─────────────────────────────────────
DATABASE_URL=postgresql://cryptotrade:cryptotrade@localhost:5432/cryptotrade?schema=public

# ─── Docker PostgreSQL ─────────────────────────────────────────
POSTGRES_USER=cryptotrade
POSTGRES_PASSWORD=cryptotrade
POSTGRES_DB=cryptotrade
POSTGRES_PORT=5432
