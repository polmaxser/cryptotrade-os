generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////////////

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum PortfolioType {
  SPOT
  FUTURES
  DEFI
  NFT
}

enum MarginType {
  ISOLATED
  CROSS
}

enum DeFiPositionType {
  LIQUIDITY_POOL
  STAKING
  LENDING
  BORROWING
  YIELD_FARMING
}

enum SubscriptionPlan {
  FREE
  STANDARD
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum TradeSource {
  MANUAL
  BINANCE
  BYBIT
  OKX
  KUCOIN
}

enum ExchangeProvider {
  BINANCE
  BYBIT
  OKX
  KUCOIN
}

enum CoachInsightPattern {
  REVENGE_TRADING
  HOLDING_LOSERS_TOO_LONG
  CUTTING_WINNERS_SHORT
  TIME_OF_DAY_WEAKNESS
  TAG_CORRELATION
  OVERTRADING
  POSITION_SIZE_INCONSISTENCY
}

enum CoachInsightStatus {
  NEW
  CONFIRMED
  DISMISSED
}

enum AiReportType {
  DAILY
  WEEKLY
  MONTHLY
}

/// Ready-made, parametrizable templates — Strategy's entry/exit criteria are free
/// text (deliberately, see Package 6.1) and so can't be executed programmatically.
enum BacktestTemplate {
  MA_CROSSOVER
  RSI_THRESHOLD
  DONCHIAN_BREAKOUT
}

//////////////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////////////

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  avatarUrl    String?

  isActive        Boolean   @default(true)
  emailVerifiedAt DateTime?

  twoFactorSecret  String?
  twoFactorEnabled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships       WorkspaceMember[]
  sentInvitations   WorkspaceInvitation[]
  refreshTokens     RefreshToken[]

  trades       Trade[]
  portfolios   Portfolio[]
  subscription Subscription?

  promoCodeRedemptions PromoCodeRedemption[]

  journalEntries JournalEntry[]
  journalTags    JournalTag[]

  watchlistItems WatchlistItem[]
  priceAlerts    PriceAlert[]
  notes          Note[]

  exchangeConnections ExchangeConnection[]

  defiPositions DeFiPosition[]
  nftHoldings   NftHolding[]

  coachInsights CoachInsight[]
  aiReports     AiReport[]
  strategies    Strategy[]
  backtestRuns  BacktestRun[]

  @@index([email])
  @@map("users")
}

//////////////////////////////////////////////////////////////
// WORKSPACE
//////////////////////////////////////////////////////////////

model Workspace {
  id          String   @id @default(cuid())

  name        String
  slug        String   @unique

  description String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     WorkspaceMember[]
  invitations WorkspaceInvitation[]

  @@index([slug])
  @@map("workspaces")
}

//////////////////////////////////////////////////////////////
// WORKSPACE MEMBER
//////////////////////////////////////////////////////////////

model WorkspaceMember {
  id String @id @default(cuid())

  role WorkspaceRole @default(MEMBER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  userId      String

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])

  @@index([workspaceId])

  @@index([userId])

  @@map("workspace_members")
}

//////////////////////////////////////////////////////////////
// WORKSPACE INVITATION
//////////////////////////////////////////////////////////////

model WorkspaceInvitation {
  id String @id @default(cuid())

  email String
  role  WorkspaceRole @default(MEMBER)

  tokenHash String @unique

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  invitedByUserId String
  invitedBy       User   @relation(fields: [invitedByUserId], references: [id], onDelete: Cascade)

  expiresAt  DateTime
  acceptedAt DateTime?
  revokedAt  DateTime?

  createdAt DateTime @default(now())

  @@index([workspaceId])
  @@index([email])
  @@map("workspace_invitations")
}

//////////////////////////////////////////////////////////////
// REFRESH TOKEN
//////////////////////////////////////////////////////////////

model RefreshToken {
  id String @id @default(cuid())

  tokenHash String @unique

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  userAgent String?
  ipAddress String?

  expiresAt DateTime
  revokedAt DateTime?

  replacedByTokenHash String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

//////////////////////////////////////////////////////////////
// PORTFOLIO
//////////////////////////////////////////////////////////////

model Portfolio {
  id String @id @default(cuid())

  name        String
  description String?

  type         PortfolioType @default(SPOT)
  baseCurrency String        @default("USDT")

  /// Used to express Max Drawdown as a percentage of equity, not just $. Null until the user sets it.
  startingBalance Decimal? @db.Decimal(20, 8)

  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  trades        Trade[]
  defiPositions DeFiPosition[]
  nftHoldings   NftHolding[]

  @@index([userId])
  @@map("portfolios")
}

//////////////////////////////////////////////////////////////
// EXCHANGE CONNECTIONS
//////////////////////////////////////////////////////////////

model ExchangeConnection {
  id String @id @default(cuid())

  exchange ExchangeProvider
  label    String

  /// AES-256-GCM encrypted — never stored or returned in plaintext.
  encryptedApiKey    String
  encryptedApiSecret String
  /// Some exchanges (e.g. OKX) require a third credential set at key creation time.
  encryptedApiPassphrase String?

  /// Last 4 characters of the real key, for display/identification only.
  apiKeyPreview String

  lastImportedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  trades Trade[]

  @@index([userId])
  @@map("exchange_connections")
}

//////////////////////////////////////////////////////////////
// TRADE
//////////////////////////////////////////////////////////////

model Trade {
  id String @id @default(cuid())

  symbol String

  side String

  /// Free-text label — kept for backward compatibility with trades created before
  /// Strategy became a formal entity. New/edited trades should set strategyId instead.
  strategy String?

  strategyId String?
  strategyRef Strategy? @relation(fields: [strategyId], references: [id], onDelete: SetNull)

  entryPrice Decimal @db.Decimal(20, 8)

  exitPrice Decimal? @db.Decimal(20, 8)

  /// Planned exit if the trade goes against the position — the risk basis for R-Multiple. Null when not set.
  stopLossPrice Decimal? @db.Decimal(20, 8)

  /// Futures-only. Null for spot trades.
  leverage   Int?
  marginType MarginType?

  quantity Decimal @db.Decimal(20, 8)

  pnl Decimal? @db.Decimal(20, 8)

  pnlPercent Decimal? @db.Decimal(10, 4)

  status String @default("OPEN")

  notes String?

  openedAt DateTime

  closedAt DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  portfolioId String?

  portfolio Portfolio? @relation(fields: [portfolioId], references: [id], onDelete: Restrict)

  /// MANUAL unless imported from a connected exchange.
  source TradeSource @default(MANUAL)

  exchangeConnectionId String?
  exchangeConnection   ExchangeConnection? @relation(fields: [exchangeConnectionId], references: [id], onDelete: SetNull)

  journalEntries JournalEntry[]

  @@index([userId])

  @@index([portfolioId])

  @@index([symbol])

  @@index([status])

  @@index([exchangeConnectionId])

  @@index([strategyId])

  @@map("trades")
}

//////////////////////////////////////////////////////////////
// DEFI POSITIONS
//////////////////////////////////////////////////////////////

model DeFiPosition {
  id String @id @default(cuid())

  protocol String
  type     DeFiPositionType

  /// e.g. "ETH/USDC" for an LP position, "ETH" for staking.
  asset String

  amount   Decimal @db.Decimal(20, 8)
  valueUsd Decimal @db.Decimal(20, 2)
  apy      Decimal? @db.Decimal(6, 2)

  notes String?

  openedAt DateTime
  closedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  portfolioId String?
  portfolio   Portfolio? @relation(fields: [portfolioId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([portfolioId])
  @@map("defi_positions")
}

//////////////////////////////////////////////////////////////
// NFT HOLDINGS
//////////////////////////////////////////////////////////////

model NftHolding {
  id String @id @default(cuid())

  collectionName  String
  tokenId         String
  contractAddress String?
  imageUrl        String?

  acquiredPriceUsd    Decimal? @db.Decimal(20, 2)
  currentFloorPriceUsd Decimal? @db.Decimal(20, 2)

  notes String?

  acquiredAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  portfolioId String?
  portfolio   Portfolio? @relation(fields: [portfolioId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([portfolioId])
  @@map("nft_holdings")
}

//////////////////////////////////////////////////////////////
// SUBSCRIPTION
//////////////////////////////////////////////////////////////

model Subscription {
  id String @id @default(cuid())

  plan   SubscriptionPlan   @default(FREE)
  status SubscriptionStatus @default(ACTIVE)

  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  stripePriceId        String?

  currentPeriodEnd  DateTime?
  cancelAtPeriodEnd Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@map("subscriptions")
}

//////////////////////////////////////////////////////////////
// PROMO CODE
//////////////////////////////////////////////////////////////

model PromoCode {
  id String @id @default(cuid())

  code        String  @unique
  description String?

  grantsPlan SubscriptionPlan
  freeDays   Int

  maxRedemptions  Int?
  redemptionCount Int  @default(0)
  isActive        Boolean @default(true)
  expiresAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  redemptions PromoCodeRedemption[]

  @@map("promo_codes")
}

model PromoCodeRedemption {
  id String @id @default(cuid())

  promoCodeId String
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  redeemedAt DateTime @default(now())

  @@unique([promoCodeId, userId])
  @@index([promoCodeId])
  @@map("promo_code_redemptions")
}

//////////////////////////////////////////////////////////////
// JOURNAL
//////////////////////////////////////////////////////////////

enum JournalTagCategory {
  MISTAKE
  EMOTION
  STRATEGY
}

model JournalEntry {
  id String @id @default(cuid())

  content String

  /// Public URLs of uploaded screenshots — no per-image metadata needed yet.
  screenshotUrls String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Optional — an entry can reflect on a specific trade or stand alone (e.g. a daily reflection).
  tradeId String?
  trade   Trade?  @relation(fields: [tradeId], references: [id], onDelete: SetNull)

  tags JournalTag[]

  @@index([userId])
  @@index([tradeId])
  @@map("journal_entries")
}

model JournalTag {
  id String @id @default(cuid())

  name     String
  category JournalTagCategory

  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  entries JournalEntry[]

  @@unique([userId, category, name])
  @@index([userId])
  @@map("journal_tags")
}

//////////////////////////////////////////////////////////////
// WATCHLIST
//////////////////////////////////////////////////////////////

model WatchlistItem {
  id String @id @default(cuid())

  /// CoinGecko coin id — the canonical key for price lookups.
  coinId String
  symbol String
  name   String

  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, coinId])
  @@index([userId])
  @@map("watchlist_items")
}

//////////////////////////////////////////////////////////////
// ALERTS
//////////////////////////////////////////////////////////////

enum AlertDirection {
  ABOVE
  BELOW
}

enum AlertStatus {
  ACTIVE
  TRIGGERED
}

model PriceAlert {
  id String @id @default(cuid())

  coinId      String
  symbol      String
  direction   AlertDirection
  targetPrice Decimal        @db.Decimal(20, 8)
  status      AlertStatus    @default(ACTIVE)

  triggeredAt DateTime?

  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("price_alerts")
}

//////////////////////////////////////////////////////////////
// NOTES
//////////////////////////////////////////////////////////////

model Note {
  id String @id @default(cuid())

  title   String
  content String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notes")
}

//////////////////////////////////////////////////////////////
// AI COACH
//////////////////////////////////////////////////////////////

model CoachInsight {
  id String @id @default(cuid())

  pattern CoachInsightPattern
  status  CoachInsightStatus  @default(NEW)

  title       String
  description String

  /// The computed numbers the finding is based on (means, counts, sample sizes) —
  /// kept alongside the LLM-phrased text so a finding stays inspectable/auditable.
  metrics Json

  /// Trades the finding is grounded in — no join table needed for a read-only reference list.
  relatedTradeIds String[] @default([])

  periodStart DateTime
  periodEnd   DateTime

  /// Set when the trader marks the finding as confirmed or dismissed.
  reviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, pattern])
  @@map("coach_insights")
}

//////////////////////////////////////////////////////////////
// AI REPORTS
//////////////////////////////////////////////////////////////

model AiReport {
  id String @id @default(cuid())

  type AiReportType

  title   String
  summary String

  /// Computed analytics for the period (and, for weekly/monthly, the prior
  /// period for comparison) — kept alongside the LLM text for auditability,
  /// same pattern as CoachInsight.metrics.
  metrics Json

  periodStart DateTime
  periodEnd   DateTime

  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, periodStart])
  @@index([userId])
  @@index([userId, type])
  @@map("ai_reports")
}

//////////////////////////////////////////////////////////////
// STRATEGIES
//////////////////////////////////////////////////////////////

model Strategy {
  id String @id @default(cuid())

  name        String
  description String?

  /// What triggers entering a position under this strategy.
  entryCriteria String?
  /// What triggers exiting — take-profit/stop-loss logic, invalidation conditions.
  exitCriteria String?
  /// Position sizing, stop-loss placement, max-risk-per-trade rules.
  riskManagement String?

  /// Free text (e.g. "15m", "4h", "1d") — traders mix conventions, not worth a rigid enum.
  timeframe String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  trades Trade[]
  backtestRuns BacktestRun[]

  @@unique([userId, name])
  @@index([userId])
  @@map("strategies")
}

//////////////////////////////////////////////////////////////
// BACKTESTS
//////////////////////////////////////////////////////////////

model BacktestRun {
  id String @id @default(cuid())

  template BacktestTemplate

  symbol    String
  /// Binance kline interval string (e.g. "1h", "4h", "1d").
  timeframe String

  periodStart DateTime
  periodEnd   DateTime

  /// Template-specific parameters (e.g. { fastPeriod, slowPeriod } for MA_CROSSOVER).
  params Json

  startingCapital Decimal @db.Decimal(20, 2)
  /// Per-trade fee, as a percent (e.g. 0.1 = 0.1%).
  feePercent      Decimal @db.Decimal(6, 4) @default(0.1)

  /// { totalTrades, winRate, totalPnlPercent, profitFactor, maxDrawdownPercent, finalEquity }
  summary Json
  /// [{ time, equity }, ...] — sampled per closed bar.
  equityCurve Json
  /// [{ side, entryTime, entryPrice, exitTime, exitPrice, pnlPercent }, ...]
  trades Json

  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Optional organizational link — the run isn't derived from the Strategy's
  /// free-text criteria, it's tagged onto it for the trader's own reference.
  strategyId String?
  strategy   Strategy? @relation(fields: [strategyId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([strategyId])
  @@map("backtest_runs")
}

enum EconomicEventCategory {
  FOMC
  CPI
  NFP
}

enum EconomicEventImportance {
  HIGH
  MEDIUM
  LOW
}

/// Global reference data (not user-owned) — macro calendar entries such as
/// FOMC rate decisions, CPI releases, and NFP/Employment Situation reports.
/// Seeded from official schedules (Fed, BLS) rather than a live feed, since
/// no reliable free real-time economic-calendar API exists (Finnhub gates
/// it behind a paid plan, Trading Economics is paid-only, FRED has no FOMC
/// data). Meant to be kept current via the future Admin Panel (Package 6.4).
model EconomicEvent {
  id String @id @default(cuid())

  category   EconomicEventCategory
  importance EconomicEventImportance
  country    String                   @default("US")

  title       String
  description String?

  eventDate DateTime

  forecast String?
  previous String?
  actual   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, eventDate])
  @@index([eventDate])
  @@index([category])
  @@map("economic_events")
}