generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////////////

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum PortfolioType {
  SPOT
}

enum SubscriptionPlan {
  FREE
  STANDARD
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum TradeSource {
  MANUAL
  BINANCE
  BYBIT
  OKX
}

enum ExchangeProvider {
  BINANCE
  BYBIT
  OKX
}

//////////////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////////////

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  avatarUrl    String?

  isActive        Boolean   @default(true)
  emailVerifiedAt DateTime?

  twoFactorSecret  String?
  twoFactorEnabled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships       WorkspaceMember[]
  sentInvitations   WorkspaceInvitation[]
  refreshTokens     RefreshToken[]

  trades       Trade[]
  portfolios   Portfolio[]
  subscription Subscription?

  promoCodeRedemptions PromoCodeRedemption[]

  journalEntries JournalEntry[]
  journalTags    JournalTag[]

  watchlistItems WatchlistItem[]
  priceAlerts    PriceAlert[]
  notes          Note[]

  exchangeConnections ExchangeConnection[]

  @@index([email])
  @@map("users")
}

//////////////////////////////////////////////////////////////
// WORKSPACE
//////////////////////////////////////////////////////////////

model Workspace {
  id          String   @id @default(cuid())

  name        String
  slug        String   @unique

  description String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     WorkspaceMember[]
  invitations WorkspaceInvitation[]

  @@index([slug])
  @@map("workspaces")
}

//////////////////////////////////////////////////////////////
// WORKSPACE MEMBER
//////////////////////////////////////////////////////////////

model WorkspaceMember {
  id String @id @default(cuid())

  role WorkspaceRole @default(MEMBER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  userId      String

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])

  @@index([workspaceId])

  @@index([userId])

  @@map("workspace_members")
}

//////////////////////////////////////////////////////////////
// WORKSPACE INVITATION
//////////////////////////////////////////////////////////////

model WorkspaceInvitation {
  id String @id @default(cuid())

  email String
  role  WorkspaceRole @default(MEMBER)

  tokenHash String @unique

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  invitedByUserId String
  invitedBy       User   @relation(fields: [invitedByUserId], references: [id], onDelete: Cascade)

  expiresAt  DateTime
  acceptedAt DateTime?
  revokedAt  DateTime?

  createdAt DateTime @default(now())

  @@index([workspaceId])
  @@index([email])
  @@map("workspace_invitations")
}

//////////////////////////////////////////////////////////////
// REFRESH TOKEN
//////////////////////////////////////////////////////////////

model RefreshToken {
  id String @id @default(cuid())

  tokenHash String @unique

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  userAgent String?
  ipAddress String?

  expiresAt DateTime
  revokedAt DateTime?

  replacedByTokenHash String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

//////////////////////////////////////////////////////////////
// PORTFOLIO
//////////////////////////////////////////////////////////////

model Portfolio {
  id String @id @default(cuid())

  name        String
  description String?

  type         PortfolioType @default(SPOT)
  baseCurrency String        @default("USDT")

  /// Used to express Max Drawdown as a percentage of equity, not just $. Null until the user sets it.
  startingBalance Decimal? @db.Decimal(20, 8)

  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  trades Trade[]

  @@index([userId])
  @@map("portfolios")
}

//////////////////////////////////////////////////////////////
// EXCHANGE CONNECTIONS
//////////////////////////////////////////////////////////////

model ExchangeConnection {
  id String @id @default(cuid())

  exchange ExchangeProvider
  label    String

  /// AES-256-GCM encrypted — never stored or returned in plaintext.
  encryptedApiKey    String
  encryptedApiSecret String
  /// Some exchanges (e.g. OKX) require a third credential set at key creation time.
  encryptedApiPassphrase String?

  /// Last 4 characters of the real key, for display/identification only.
  apiKeyPreview String

  lastImportedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  trades Trade[]

  @@index([userId])
  @@map("exchange_connections")
}

//////////////////////////////////////////////////////////////
// TRADE
//////////////////////////////////////////////////////////////

model Trade {
  id String @id @default(cuid())

  symbol String

  side String

  strategy String?

  entryPrice Decimal @db.Decimal(20, 8)

  exitPrice Decimal? @db.Decimal(20, 8)

  /// Planned exit if the trade goes against the position — the risk basis for R-Multiple. Null when not set.
  stopLossPrice Decimal? @db.Decimal(20, 8)

  quantity Decimal @db.Decimal(20, 8)

  pnl Decimal? @db.Decimal(20, 8)

  pnlPercent Decimal? @db.Decimal(10, 4)

  status String @default("OPEN")

  notes String?

  openedAt DateTime

  closedAt DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  portfolioId String?

  portfolio Portfolio? @relation(fields: [portfolioId], references: [id], onDelete: Restrict)

  /// MANUAL unless imported from a connected exchange.
  source TradeSource @default(MANUAL)

  exchangeConnectionId String?
  exchangeConnection   ExchangeConnection? @relation(fields: [exchangeConnectionId], references: [id], onDelete: SetNull)

  journalEntries JournalEntry[]

  @@index([userId])

  @@index([portfolioId])

  @@index([symbol])

  @@index([status])

  @@index([exchangeConnectionId])

  @@map("trades")
}

//////////////////////////////////////////////////////////////
// SUBSCRIPTION
//////////////////////////////////////////////////////////////

model Subscription {
  id String @id @default(cuid())

  plan   SubscriptionPlan   @default(FREE)
  status SubscriptionStatus @default(ACTIVE)

  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  stripePriceId        String?

  currentPeriodEnd  DateTime?
  cancelAtPeriodEnd Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@map("subscriptions")
}

//////////////////////////////////////////////////////////////
// PROMO CODE
//////////////////////////////////////////////////////////////

model PromoCode {
  id String @id @default(cuid())

  code        String  @unique
  description String?

  grantsPlan SubscriptionPlan
  freeDays   Int

  maxRedemptions  Int?
  redemptionCount Int  @default(0)
  isActive        Boolean @default(true)
  expiresAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  redemptions PromoCodeRedemption[]

  @@map("promo_codes")
}

model PromoCodeRedemption {
  id String @id @default(cuid())

  promoCodeId String
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  redeemedAt DateTime @default(now())

  @@unique([promoCodeId, userId])
  @@index([promoCodeId])
  @@map("promo_code_redemptions")
}

//////////////////////////////////////////////////////////////
// JOURNAL
//////////////////////////////////////////////////////////////

enum JournalTagCategory {
  MISTAKE
  EMOTION
  STRATEGY
}

model JournalEntry {
  id String @id @default(cuid())

  content String

  /// Public URLs of uploaded screenshots — no per-image metadata needed yet.
  screenshotUrls String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Optional — an entry can reflect on a specific trade or stand alone (e.g. a daily reflection).
  tradeId String?
  trade   Trade?  @relation(fields: [tradeId], references: [id], onDelete: SetNull)

  tags JournalTag[]

  @@index([userId])
  @@index([tradeId])
  @@map("journal_entries")
}

model JournalTag {
  id String @id @default(cuid())

  name     String
  category JournalTagCategory

  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  entries JournalEntry[]

  @@unique([userId, category, name])
  @@index([userId])
  @@map("journal_tags")
}

//////////////////////////////////////////////////////////////
// WATCHLIST
//////////////////////////////////////////////////////////////

model WatchlistItem {
  id String @id @default(cuid())

  /// CoinGecko coin id — the canonical key for price lookups.
  coinId String
  symbol String
  name   String

  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, coinId])
  @@index([userId])
  @@map("watchlist_items")
}

//////////////////////////////////////////////////////////////
// ALERTS
//////////////////////////////////////////////////////////////

enum AlertDirection {
  ABOVE
  BELOW
}

enum AlertStatus {
  ACTIVE
  TRIGGERED
}

model PriceAlert {
  id String @id @default(cuid())

  coinId      String
  symbol      String
  direction   AlertDirection
  targetPrice Decimal        @db.Decimal(20, 8)
  status      AlertStatus    @default(ACTIVE)

  triggeredAt DateTime?

  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("price_alerts")
}

//////////////////////////////////////////////////////////////
// NOTES
//////////////////////////////////////////////////////////////

model Note {
  id String @id @default(cuid())

  title   String
  content String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notes")
}